# claude-notify-sounds 使用者設定
# install.sh 會把這份複製到 ~/.config/claude-notify-sounds/env
# 改完「即時生效」，不需重裝（hook 每次觸發都會重讀）
#
# 純音效版：兩個時機都只用 afplay 播系統音效，不跳任何桌面通知。

# ── 換你了 / 這輪結束（Stop hook）──
# 註：Stop = 我這輪做完、把球丟回給你（含我用文字反問你的情況），不是字面「答完一段話」
NOTIFY_DONE_ENABLED=1             # 1=開 0=關
NOTIFY_DONE_SOUND=Glass

# ── 需要你回應 / 批准（Notification hook）──
NOTIFY_WAITING_ENABLED=1          # 1=開 0=關
NOTIFY_WAITING_SOUND=Funk

# 可用音效（/System/Library/Sounds）：
#   Basso Blow Bottle Frog Funk Glass Hero Morse Ping Pop Purr Sosumi Submarine Tink
